{
  "ConnectionStrings": {
    "SQLite": "Data Source=Data/geonode.db",
    "Redis": "localhost:6379,abortConnect=false"
  },
  "KtnSecurity": {
    "Enabled": false,
    "PacketHeaderName": "KTN",
    "PacketHeaderValue": "KTN",
    "EncryptRequestHeader": "X-KTN-Encrypt",
    "ClientIdHeader": "X-Client-Id",
    "RsaKeySize": 2048,
    "ServerPrivateKeyPath": "KtnSecurity/server_private.pem",
    "ServerPublicKeyPath": "KtnSecurity/server_public.pem"
  },
  "Server": {
    "Address": "localhost",
    "HttpPort": 5186,
    "EnableHttps": false,
    "HttpsPort": 7044,
    "DebugMode": false,
    "HttpsCertificatePath": "",
    "HttpsPrivateKeyPath": "",
    "HttpsCertificatePassword": ""
  },
  "Redis": {
    "Enabled": false,
    "InstanceName": "KTNLocation:"
  },
  "Cache": {
    "DefaultTtlSeconds": 300,
    "IpTtlSeconds": 900,
    "GpsTtlSeconds": 300
  },
  "GeoProviders": {
    "AutoDownloadOnStartup": true,
    "UpdateIntervalHours": 24,
    "ProviderOrder": [
      "ip2region",
      "geolite",
      "loyalsoldier",
      "geoip2cn"
    ],
    "Ip2RegionV4XdbPath": "GeoData/ip2region/ip2region_v4.xdb",
    "Ip2RegionV6XdbPath": "GeoData/ip2region/ip2region_v6.xdb",
    "Ip2RegionV4XdbUrl": "https://raw.githubusercontent.com/lionsoul2014/ip2region/master/data/ip2region_v4.xdb",
    "Ip2RegionV6XdbUrl": "https://raw.githubusercontent.com/lionsoul2014/ip2region/master/data/ip2region_v6.xdb",
    "GeoLiteCountryMmdbPath": "GeoData/geolite/GeoLite2-Country.mmdb",
    "GeoLiteCountryMmdbUrl": "https://github.com/P3TERX/GeoLite.mmdb/raw/download/GeoLite2-Country.mmdb",
    "LoyalSoldierCountryMmdbPath": "GeoData/loyalsoldier/Country.mmdb",
    "LoyalSoldierCountryMmdbUrl": "https://raw.githubusercontent.com/Loyalsoldier/geoip/release/Country.mmdb",
    "GeoIP2CnMmdbPath": "GeoData/geoip2cn/Country.mmdb",
    "GeoIP2CnMmdbUrl": "https://raw.githubusercontent.com/Hackl0us/GeoIP2-CN/release/Country.mmdb"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  }
}
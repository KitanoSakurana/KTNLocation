# -----------------------------------------------------------------------------
# KTNLocation .gitignore
# -----------------------------------------------------------------------------

# Build artifacts
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# .NET cache / generated files
*.cache
*.pdb
*.mdb
*.opendb
*.VC.db
*.ilk
*.tmp
*.log
*.tlog

# IDE / user-specific files
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.DotSettings.user

# VS Code local files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# NuGet packages
*.nupkg
*.snupkg
packages/
!packages/build/

# Test / coverage artifacts
TestResults/
coverage/
*.coverage
*.coveragexml

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Environment files / secrets
.env
.env.*
!.env.example
Api/KtnSecurity/*.pem
Api/KtnSecurity/*.key
Api/KtnSecurity/*.crt

# Runtime database / cache files
Api/Data/*.db
Api/Data/*.db-*
*.sqlite
*.sqlite3

# Downloaded GeoIP datasets (large, regenerated by provider bootstrap/update)
Api/GeoData/**/*.mmdb
Api/GeoData/**/*.xdb
Api/GeoData/**/*.dat
Api/GeoData/**/*.csv
Api/GeoData/**/*.zip
Api/GeoData/**/*.gz
Api/GeoData/**/*.tmp
